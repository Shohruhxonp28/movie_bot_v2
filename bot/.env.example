# Bot sozlamalari
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789,987654321
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/kinobot
BOT_USERNAME=your_bot_username

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# Kanallar
PUBLIC_CHANNEL_ID=-1001234567890
PUBLIC_CHANNEL_USERNAME=your_public_channel

MAIN_CHANNEL_ID=-1001234567891
MAIN_CHANNEL_USERNAME=your_main_channel

# Redis (ixtiyoriy)
REDIS_URL=redis://localhost:6379/0

# Poster watermark
WATERMARK_TEXT=@your_bot_username

# Bot sozlamalari
DEFAULT_LANGUAGE=uz
MAX_SEARCH_RESULTS=10
DAILY_DOWNLOAD_LIMIT=5
VIP_DAILY_LIMIT=50
